# =============================================================================
# SECRETS — paste real values here (never commit this file; it is gitignored)
# =============================================================================
# Get keys from:
#   OpenRouter: https://openrouter.ai/keys
#   Weights & Biases: https://wandb.ai/authorize
#   Hugging Face (optional, for gated/private Hub downloads): https://huggingface.co/settings/tokens
#
# Leave a secret blank to skip that integration. Placeholders are treated as unset.

OPENROUTER_API_KEY=
WANDB_API_KEY=
HF_TOKEN=

# --- Discord bot (Chloride) — https://github.com/S4IL21/chloride ---
# Create a bot at https://discord.com/developers/applications (enable Message Content Intent).
DISCORD_TOKEN=
# Incoming webhook URL for outbound analysis notifications (Channel → Integrations → Webhooks).
# One-way only — does not replace DISCORD_TOKEN for the interactive Chloride bot.
DISCORD_WEBHOOK_URL=
# Optional override for the bot LLM key (defaults to OPENROUTER_API_KEY).
DISCORD_AI_API_KEY=
AI_API_KEY=
# Optional model slug when using OpenRouter bridge (default: anthropic/claude-sonnet-4.5).
DISCORD_AI_MODEL=
# Set to 0 to disable auto OpenRouter base URL wiring.
DISCORD_USE_OPENROUTER=1
# Optional override of bot workspace path (default: discord/smol-doc-analyzer).
DISCORD_BOT_CONFIG_DIR=

# =============================================================================
# Non-secret settings (safe defaults; override as needed)
# =============================================================================

# Any model slug OpenRouter supports, e.g.:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   meta-llama/llama-3.1-70b-instruct
GENERATION_MODEL=anthropic/claude-sonnet-4.5

GENERATION_MAX_CONCURRENCY=4
GENERATION_MAX_RETRIES=5

# Optional, sent as attribution headers to OpenRouter (used in their
# public rankings). Safe to leave blank.
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=insurance-doc-ai

SKELETON_OUTPUT_DIR=data/synthetic/skeletons
DOCUMENT_OUTPUT_DIR=data/synthetic/documents
MEMO_OUTPUT_DIR=data/synthetic/memos
NOISY_OUTPUT_DIR=data/synthetic/noisy
PROVENANCE_LOG_PATH=data/provenance_log.jsonl
PROFILES_DIR=data/profiles
RAW_DATA_DIR=data/raw
SPLITS_PATH=data/synthetic/splits.json
EVALUATION_REPORTS_DIR=evaluation/reports
MODELS_DIR=models

# --- Chained inference pipeline (Phase 5 memo path) ---
# DICIE (src/docie/) also caches pages under PIPELINE_CACHE_DIR/docie/
# and writes batch outputs under PIPELINE_OUTPUT_DIR/docie/.
# Optional extras: pip install -e ".[ocr]"  /  pip install -e ".[serve]"
PIPELINE_OUTPUT_DIR=data/pipeline
PIPELINE_CACHE_DIR=data/pipeline/cache

# Vision LLM stage (local multimodal refine after extraction).
# Default chain converts PNG/PDF → markdown first, then feeds markdown to
# this stage (token-efficient). Set VISION_LLM_USE_IMAGE=1 to also attach
# the page image for visual verification on high-RAM hosts.
# Set VISION_LLM_LOAD=1 and/or VISION_LLM_MODEL_PATH to load a real local VLM.
VISION_LLM_ENABLED=true
VISION_LLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
VISION_LLM_MODEL_PATH=
VISION_LLM_LOAD=0
VISION_LLM_USE_IMAGE=0

# Optional local generative summarizer (Phase 4). Empty → template memo
# grounded in upstream classify/extract/vision payloads.
SUMMARIZER_MODEL=
SUMMARIZER_MODEL_PATH=

# Weights & Biases experiment tracking (training, eval, generation runs).
WANDB_PROJECT=smol-doc-analyzer
# Optional team/user entity; leave blank to use your default account.
WANDB_ENTITY=
# online | offline | disabled
WANDB_MODE=online
