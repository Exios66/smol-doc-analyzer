# API key for OpenRouter (https://openrouter.ai/keys). Used ONLY for
# synthetic data generation (Stage A / Stage B) -- see docs/data_provenance.md.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Any model slug OpenRouter supports, e.g.:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   meta-llama/llama-3.1-70b-instruct
GENERATION_MODEL=anthropic/claude-sonnet-4.5

GENERATION_MAX_CONCURRENCY=4
GENERATION_MAX_RETRIES=5

# Optional, sent as attribution headers to OpenRouter (used in their
# public rankings). Safe to leave blank.
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=insurance-doc-ai

SKELETON_OUTPUT_DIR=data/synthetic/skeletons
DOCUMENT_OUTPUT_DIR=data/synthetic/documents
MEMO_OUTPUT_DIR=data/synthetic/memos
NOISY_OUTPUT_DIR=data/synthetic/noisy
PROVENANCE_LOG_PATH=data/provenance_log.jsonl
PROFILES_DIR=data/profiles
RAW_DATA_DIR=data/raw
SPLITS_PATH=data/synthetic/splits.json
EVALUATION_REPORTS_DIR=evaluation/reports
MODELS_DIR=models

# Weights & Biases experiment tracking (training, eval, generation runs).
# Create a key at https://wandb.ai/authorize — leave blank for offline mode.
WANDB_API_KEY=
WANDB_PROJECT=smol-doc-analyzer
# Optional team/user entity; leave blank to use your default account.
WANDB_ENTITY=
# online | offline | disabled
WANDB_MODE=online
